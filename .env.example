# Maximum number of cards allowed per board
PUBLIC_MAX_CARDS_PER_BOARD=500
# Delay in milliseconds before saving changes to the local DB
PUBLIC_DB_SAVE_DELAY_MS=5000
# Options: 'local' (default, uses backend PGlite), or 'temp' (in-memory scratchpad mode)
PUBLIC_DB_MODE=local

PUBLIC_MAX_RECURSIVE_BOARDS=10

ORIGIN=http://localhost:5173

# --- Database & Sync Variables ---
# Local/Docker: postgres://postgres:password@localhost:5432/lattice
# Supabase: postgres://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# (Use port 6543 for Transaction mode / 5432 for Session mode)
DATABASE_URL=
# Set to 'true' to force SSL (default is true for *.supabase.com and *.neon.tech)
DATABASE_SSL=false