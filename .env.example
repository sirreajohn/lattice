# Maximum number of cards allowed per board
PUBLIC_MAX_CARDS_PER_BOARD=500
# Delay in milliseconds before saving changes to the local DB
PUBLIC_DB_SAVE_DELAY_MS=5000
# Options: 'local' (default, uses backend PGlite), or 'temp' (in-memory scratchpad mode)
PUBLIC_DB_MODE=temp

PUBLIC_MAX_RECURSIVE_BOARDS=10